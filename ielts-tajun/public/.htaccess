# SEO and Security Configuration for thiieltstrenmay.com

# Enable URL Rewriting
RewriteEngine On

# Block access to admin subdomains and paths
RewriteCond %{HTTP_HOST} ^admin\.thiieltstrenmay\.com [NC]
RewriteRule ^(.*)$ https://thiieltstrenmay.com/ [R=301,L]

# Additional admin subdomain protection
RewriteCond %{HTTP_HOST} admin\.thiieltstrenmay\.com [NC]
RewriteRule ^(.*)$ https://thiieltstrenmay.com/ [R=301,L]

# Block admin paths
RewriteRule ^admin/ - [F,L]
RewriteRule ^manage_student - [F,L]
RewriteRule ^manage_test - [F,L]

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Force www removal (canonical URL)
RewriteCond %{HTTP_HOST} ^www\.thiieltstrenmay\.com [NC]
RewriteRule ^(.*)$ https://thiieltstrenmay.com/$1 [R=301,L]

# Handle React Router (SPA)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]

# Security Headers
<IfModule mod_headers.c>
    # SEO Headers
    Header always set X-Robots-Tag "index, follow"
    
    # Security Headers
    Header always set X-Content-Type-Options nosniff
    Header always set X-Frame-Options DENY
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Cache Control for better performance
    <FilesMatch "\.(css|js|png|jpg|jpeg|gif|ico|svg)$">
        Header set Cache-Control "public, max-age=31536000"
    </FilesMatch>
    
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>
</IfModule>

# Compression for better performance
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
</IfModule>

# Prevent access to sensitive files
<Files "robots.txt">
    Allow from all
</Files>

<Files "sitemap.xml">
    Allow from all
</Files>

# Block access to configuration files
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|inc|bak)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>