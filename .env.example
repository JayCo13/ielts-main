# Database Configuration
MYSQL_ROOT_PASSWORD=change_me_to_strong_password
MYSQL_DATABASE=ielts_practice
MYSQL_USER=ielts
MYSQL_PASSWORD=change_me_to_strong_password

# Redis Configuration
REDIS_PASSWORD=change_me_to_strong_password

# Frontend API base URL baked into the UI bundles at build time.
# docker-compose defaults both to the prod API, so on the VPS you usually
# don't need to set these. Override here only to point a build elsewhere.
# (Local `npm run dev`/`npm start` ignore these and default to http://localhost:8000.)
VITE_API_BASE_URL=https://api.thiieltstrenmay.com
REACT_APP_API_BASE_URL=https://api.thiieltstrenmay.com
